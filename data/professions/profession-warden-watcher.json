            {
              "value": "conjuration",
              "label": "Conjuration",
              "grants": {
                "sphere": "conjuration",
                "known_spell": "imbue_with_elements"
              }
            },
            {
              "value": "decimation",
              "label": "Decimation",
              "grants": {
                "sphere": "decimation",
                "known_spell": "seeking_bolt"
              }
            },
            {
              "value": "divination",
              "label": "Divination",
              "grants": {
                "sphere": "divination",
                "known_spell": "detect_the_inhumane"
              }
            },
            {
              "value": "mortification",
              "label": "Mortification",
              "grants": { "sphere": "mortification", "known_spell": "torment" }
            },
            {
              "value": "reclamation",
              "label": "Reclamation",
              "grants": {
                "sphere": "reclamation",
                "known_spell": "healing_word"
              }
            }
          ]
        },
        {
          "type": "grants_sphere",
          "count": 1,
          "from": { "source": "choice", "key": "watcher_sphere" }
        },
        {
          "type": "grants_known_spells",
          "from": {
            "source": "choice",
            "key": "watcher_sphere",
            "field": "known_spell"
          },
          "exclude": "creed_spells",
          "counts_against_known": false
        }
      ]
    },

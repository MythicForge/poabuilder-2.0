  "types": {
    "stat_bonus": {
      "category": "Stat & Defense",
      "summary": "Adds an amount to a stat, defense, or tracked max. Absorbs old armor_bonus.",
      "fields": [
        {
          "name": "stat",
          "kind": "enum",
          "enum": "stats",
          "required": true
        },
        {
          "name": "amount",
          "kind": "formula",
          "required": true,
          "hint": "signed formula OK, e.g. \"Tier * -1\"; string like \"Large\" for size_category"
        },
        {
          "name": "target",
          "kind": "string",
          "default": "self",
          "hint": "only \"self\" is computed; other-creature targets render on the card (display-only, TRACKING-SCOPE)"
        },
        {
          "name": "condition",
          "kind": "string",
          "hint": "sheet-knowable only, e.g. \"unarmored\", \"state:rage\""
        },
        {
          "name": "duration",
          "kind": "string"
        },
        {
          "name": "uses",
          "kind": "uses"
        }
      ]
    },

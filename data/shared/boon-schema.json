{
  "$meta": {
    "name": "Path of Ambition \u2014 Boon Schema",
    "version": "1.2.0",
    "source": "REFERENCE.md Boon Types (58 live + spell payload) + Description-Only (Retired)",
    "changelog": [
      "1.2.0 (R3 schema reconcile): enums.stats += spell_attack/spell_dc (display-only, wire in R4) + Brawn/Finesse/Mind/Will (attribute bumps); enums.triggers += 7 display-only triggers; stat_bonus.target & restore_resource.target relaxed enum->string (only \"self\" computes, others render on card per TRACKING-SCOPE); resistance.charges, heal.max_targets, summon.max_active, enchantment_option.max_placements changed number->formula (accept Tier/Mind/Will); craft_on_the_fly.count accepts literal \"any\" (=unlimited)."
    ],
    "rule": "A boon is tracked only if it changes a tracked quantity AND its condition is sheet-knowable. Otherwise it belongs in the feat description. See TRACKING-SCOPE.md.",
    "field_kinds": {
      "string": "free text input",
      "formula": "number or formula string (Brawn/Finesse/Mind/Will/Tier, + - * / ceil floor max)",
      "number": "integer input",
      "boolean": "checkbox",
      "enum": "select from named enum list",
      "list": "array of strings (comma-separated input)",
      "uses": "composite { count, recharge }",
      "cost": "JSON object \u2014 { \"ap\": N } and/or { \"resources\": [{ \"id\", \"amount\" }] }",
      "json": "freeform JSON object/array (validated on save)",
      "boon": "single nested boon object (must be a live type)",
      "boons": "array of nested boon objects (must be live types)",
      "options": "structured option list \u2014 value/label/description + nested tracked boons (or single effect boon)"
    }
  },
